  MMMark: {fileID: 1790305214809162582}
  StartDialog: '{"DialogName":"sad","SaveDialog":false,"Replics":[{"Actor":"Jackson","Replica":"-
    And another commando mission, butcher. Yakuzas play dirty. They give us the tea
    instead of marij*ana."},{"Actor":"Jackson","Replica":"- Their farm, where they
    are working with their hired rednecks, is near the south beach. Kill them and
    pick up their items to find dope."},{"Actor":"Jackson","Replica":"- It''s very
    dangerous, this crazy asian mafia is merciless. They all got UZI!"},{"Actor":"You","Replica":"-
    Ooo, I''m so scared!"}],"$type":"Game.DialogSystem.Dialog"}'
  EndDialog: '{"DialogName":"7775","SaveDialog":false,"Replics":[{"Actor":"Jackson","Replica":"-
    Sh*t! They got only green tea, it was small misunderstanding! Damn, uneducated
    fermers!"},{"Actor":"You","Replica":"- But they got Uzi too!"},{"Actor":"Jackson","Replica":"-
    These Japanese still strange."}],"$type":"Game.DialogSystem.Dialog"}'
  StartPosition: {fileID: 1790305214809161660}
  AdditionalPointRadius: 0
  IsDebug: 1
