  MMMark: {fileID: 1790305214809162488}
  StartDialog: '{"DialogName":"Louis_11","SaveDialog":false,"Replics":[{"Actor":"Diesel","Replica":"-
    Hi, I''m Diesel. Wanna become a member of our street-racing club? "},{"Actor":"Diesel","Replica":"-
    So, to join us, you need to pay 5000$."},{"Actor":"Diesel","Replica":"- I''m joking,
    man! Just show me what you''ve got! Take a car, drive here and we will start your
    first race!"}],"$type":"Game.DialogSystem.Dialog"}'
  EndDialog: '{"DialogName":"Kek","SaveDialog":false,"Replics":[{"Actor":"Diesel","Replica":"-
    Good skill, bro! Here your prize! So, we are the Vice street-reacing club! We
    like action, fast cars and nice job!"},{"Actor":"Diesel","Replica":"- Thus we
    pay good for every good work, cause we are taking video of epic moments!"},{"Actor":"Diesel","Replica":"-
    You are in our extreme team now, if you want it! Just come back a little later
    for the next races!"},{"Actor":"Diesel","Replica":"- Oh, yeah, see...There is
    one crazy asian at my back, his name is Lee. He''s about cars and nice job too,
    but without videos."},{"Actor":"Diesel","Replica":"- If you know what I mean."}],"$type":"Game.DialogSystem.Dialog"}'
  StartPosition: {fileID: 1790305214809161488}
  AdditionalPointRadius: 0
  IsDebug: 1
