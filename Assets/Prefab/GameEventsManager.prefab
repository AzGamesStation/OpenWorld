  TaskText: Go to bro
  PrevTask: {fileID: 0}
  NextTask: {fileID: 1790305214809162381}
  AdditionalTimer: 0
  DialogData: '{"DialogName":"987435","SaveDialog":false,"Replics":[{"Actor":"--","Replica":"Go
    to the point to find your brother."}],"$type":"Game.DialogSystem.Dialog"}'
  EndDialogData: '{"DialogName":"Start_11","SaveDialog":false,"Replics":[{"Actor":"Jackson","Replica":"-Yo!
    That''s my bro, Mumba! Hi! How do you like our City? The cool sea breeze, yeah?
    But this resort is full of crap to be honest, you know"},{"Actor":"You","Replica":"-
    Big time, that''s lit."},{"Actor":"Jackson","Replica":"- At first I''ll give you
    the small remedy. I''ve heard you''re a good cold-blooded shooter..."},{"Actor":"Jackson","Replica":"-
    Of course, if you''re the veteran of Syria, Iraq, Afghanistan and Vietnam, which
    hating our government now."},{"Actor":"Jackson","Replica":"- Such as we need here!
    There is the war that we''re losing now! The mayor sell our island, our land for
    a penny! \nSame time other bands don''t want to talk, just kill each other!"}],"$type":"Game.DialogSystem.Dialog"}'
  IsDebug: 1
  PointPosition: {fileID: 1790305214809161697}
  AdditionalPointRadius: 0
